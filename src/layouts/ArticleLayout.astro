---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  publishDate: string;
  category: string;
  readingTime?: number;
  ogImage?: string;
  sources?: Array<{ title: string; url: string; type: string }>;
}

const {
  title,
  description,
  publishDate,
  category,
  readingTime,
  ogImage,
} = Astro.props;

const siteUrl = 'https://anu.wiki';
const slug = Astro.url.pathname;
const catNames: Record<string, string> = {
  geography: '地理', history: '历史', politics: '政治',
  economy: '经济', education: '教育', culture: '文化',
};
const catName = catNames[category] || category;
const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: publishDate,
  dateModified: publishDate,
  author: {
    '@type': 'Organization',
    name: '澳洲百科 · UNILINK 研究案头',
  },
  publisher: {
    '@type': 'Organization',
    name: '澳洲百科',
    url: siteUrl,
  },
  articleSection: category,
});
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalURL={`${siteUrl}${slug}`}
  schema={articleSchema}
>
  <article class="article-body">
    <nav class="breadcrumb">
      <a href="/">首页</a> / <a href={`/category/${category}/`}>{catName}</a> / <span>{title}</span>
    </nav>
    <div class="prose">
      <h1>{title}</h1>
      <div class="meta">
        <time datetime={publishDate}>{new Date(publishDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        {readingTime && <span>{readingTime} 分钟阅读</span>}
      </div>
      <slot />
    </div>
    <nav class="back-nav">
      <a href="/">← 返回首页</a>
      <a href={`/category/${category}/`}>更多{catName}文章 →</a>
    </nav>
  </article>
</BaseLayout>
