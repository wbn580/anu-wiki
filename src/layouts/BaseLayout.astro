---
import BaseHead from '../components/BaseHead.astro';

const { title, description, ogImage, canonicalURL, schema } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalURL={canonicalURL}
      schema={schema}
    />
    <style is:global>
      @import '../styles/global.css';
      @import '../styles/editorial.css';
    </style>
    <!-- Unified lead conversion entry: assessment form, chat, sticky buttons and in-article card -->
    <script src="https://chat.anu.wiki/lead.js?v=20260702-routefix" data-site="anu-wiki" data-lang="zh-CN" data-tier="school" data-country="au" data-school="anu" data-apply-base="https://apply.anu.wiki" data-color="#2E5C3A" data-accent="#8B3A1F" async></script>
    <!-- Chat widget for lead consultation actions -->
    <script src="https://chat.anu.wiki/w.js" data-site="anu-wiki" data-lang="zh-CN" data-bot-name="UNILINK AI" data-channel="organic" data-color="#2E5C3A" data-accent="#8B3A1F" async></script>
</head>
  <body class="editorial">
    <nav class="enav" id="enav">
      <a href="/" class="ebrand">
        <span class="emark">A</span>
        <span class="etitle"><b>ANU Wiki</b></span>
      </a>
      <div class="enav-links">
        <a href="/">Home</a>
        <a href="/#articles">Articles</a>
        <a href="/about/">About</a>
      </div>
      <a href="/#articles" class="enav-cta">Browse Articles</a>
      <div class="ehamb" id="ehamb"><span></span><span></span><span></span></div>
    </nav>

    <main>
      <slot />
    </main>

    <efooter>
      <div class="efoot-grid">
        <div class="efoot-brand">
          <b>ANU Wiki</b>
          <p>The independent knowledge base for the Australian National University — admissions, academics, campus life, and student services.</p>
        </div>
        <div>
          <h4>Navigate</h4>
          <a href="/">Home</a>
          <a href="/#articles">All Articles</a>
        </div>
        <div>
          <h4>Info</h4>
          <a href="/about/">About</a>
          <a href="/sources/">Sources</a>
        </div>
        <div>
          <h4>Links</h4>
          <a href="/">Home</a>
          <a href="/#articles">Articles</a>
        </div>
      </div>
      <div class="efoot-bottom">
        <span>&copy; 2026 ANU Wiki</span>
        <span>Compiled by UNILINK · MARA 1687552 · QEAC G167</span>
      </div>
    </efooter>


    <!-- 留资入口中心化组件（吸底两按钮+桌面药丸+文中图片卡）改一处全站生效 -->
</body>
</html>
