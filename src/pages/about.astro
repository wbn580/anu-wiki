---
import BaseLayout from '../layouts/BaseLayout.astro';

const aboutSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About ANU Wiki',
  url: 'https://anu.wiki/about/',
  description: 'About ANU Wiki — the independent knowledge base for the Australian National University',
  publisher: {
    '@type': 'Organization',
    name: 'ANU Wiki',
  },
});
---

<BaseLayout
  title="About ANU Wiki"
  description="About ANU Wiki — the independent knowledge base for the Australian National University. Admissions, academics, campus life, and student services."
  schema={aboutSchema}
>
  <article class="article-body">
    <div class="prose">
      <h1>About ANU Wiki</h1>

      <section>
        <h2>What We Cover</h2>
        <p>
          ANU Wiki is an independent knowledge base dedicated to the <strong>Australian National University</strong>. We cover admissions, academics, campus life, student services, and everything you need to know about studying at ANU.
        </p>
        <p>
          Our articles are based on publicly available information from ANU's official websites, Australian Government education data, and peer-reviewed academic sources. We present information in a structured, factual format — not opinion pieces.
        </p>
      </section>

      <section>
        <h2>Sources</h2>
        <p>
          Articles cite official ANU sources, government data, and academic literature. Key sources include:
        </p>
        <ul>
          <li><a href="https://www.anu.edu.au/">ANU Official Website</a> — course information, policies, campus services</li>
          <li><a href="https://www.education.gov.au/">Australian Department of Education</a> — higher education data and policy</li>
          <li><a href="https://www.studyAustralia.gov.au/">Study Australia</a> — official international student portal</li>
          <li><a href="https://www.teqsa.gov.au/">TEQSA</a> — tertiary education quality and standards</li>
        </ul>
      </section>

      <section>
        <h2>Editorial</h2>
        <p>
          Compiled and maintained by the UNILINK editorial team, with over a decade of experience in Australian education and migration. We strive for factual accuracy without policy advocacy.
        </p>
        <p>
          <strong>Disclaimer</strong>: Content on this site is for informational purposes only and does not constitute legal, migration, or academic advice. For specific questions about study, visas, or migration, please consult a licensed professional.
        </p>
      </section>
    </div>
  </article>
</BaseLayout>
