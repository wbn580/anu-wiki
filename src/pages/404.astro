---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you requested does not exist. Return to the ANU Wiki homepage."
>
  <div class="article-body" style="text-align:center; padding-top:140px; padding-bottom:80px">
    <p style="font-family: 'Microsoft YaHei', sans-serif; font-size:48px; color:var(--euc); margin-bottom:12px">404</p>
    <h1 style="font-family: 'Microsoft YaHei', sans-serif; font-size:1.6rem; margin-bottom:12px">Page Not Found</h1>
    <p style="color:var(--muted); margin-bottom:28px">The page you requested may have been removed or never existed.</p>
    <a href="/" class="ebtn ebtn-primary">Back to Home</a>
  </div>
</BaseLayout>
