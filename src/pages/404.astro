---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="页面未找到"
  description="请求的页面不存在。请返回首页浏览澳洲百科的全部条目。"
>
  <div class="article-body" style="text-align:center; padding-top:140px; padding-bottom:80px">
    <p style="font-family: "Microsoft YaHei", sans-serif; font-size:48px; color:var(--euc); margin-bottom:12px">404</p>
    <h1 style="font-family: "Microsoft YaHei", sans-serif; font-size:1.6rem; margin-bottom:12px">页面未找到</h1>
    <p style="color:var(--muted); margin-bottom:28px">您请求的页面可能已被移除，或从未存在。</p>
    <a href="/" class="ebtn ebtn-primary">返回首页</a>
  </div>
</BaseLayout>
