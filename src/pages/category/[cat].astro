---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return [
    { params: { cat: 'geography' } },
    { params: { cat: 'history' } },
    { params: { cat: 'politics' } },
    { params: { cat: 'economy' } },
    { params: { cat: 'education' } },
    { params: { cat: 'culture' } },
  ];
}

const { cat } = Astro.params;
const catNames: Record<string, string> = {
  geography: '地理', history: '历史', politics: '政治',
  economy: '经济', education: '教育', culture: '文化',
};
const catName = catNames[cat] || cat;

const articles = await getCollection('articles', ({ data }) => data.category === cat && !data.draft);
articles.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
---

<BaseLayout
  title={`${catName} · 澳洲百科`}
  description={`澳洲百科 ${catName} 模块——全部条目按时间倒序排列。`}
>
  <article class="article-body">
    <nav class="breadcrumb">
      <a href="/">首页</a> / <span>{catName}</span>
    </nav>
    <div class="prose">
      <h1>{catName}</h1>
      <p>共 {articles.length} 篇</p>
      <ul>
        {articles.map(article => (
          <li>
            <a href={`/${article.slug}/`}>{article.data.title}</a>
            <br/><small>{article.data.description}</small>
          </li>
        ))}
      </ul>
    </div>
  </article>
</BaseLayout>
