---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  // Collect unique categories with counts, sorted by count desc
  const catCounts: Record<string, number> = {};
  for (const a of articles) {
    const c = a.data.category || 'general';
    catCounts[c] = (catCounts[c] || 0) + 1;
  }
  // Return top categories (min 2 articles)
  return Object.entries(catCounts)
    .filter(([_, count]) => count >= 2)
    .sort(([, a], [, b]) => b - a)
    .slice(0, 12)
    .map(([cat]) => ({ params: { cat } }));
}

const { cat } = Astro.params;

const articles = await getCollection('articles', ({ data }) => data.category === cat && !data.draft);
articles.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const catDisplay = cat;
---

<BaseLayout
  title={`${catDisplay} · ANU Wiki`}
  description={`ANU Wiki articles in "${catDisplay}" — ${articles.length} articles sorted by date.`}
>
  <article class="article-body">
    <nav class="breadcrumb">
      <a href="/">Home</a> / <span>{catDisplay}</span>
    </nav>
    <div class="prose">
      <h1>{catDisplay}</h1>
      <p>{articles.length} articles</p>
      <ul>
        {articles.map(article => (
          <li>
            <a href={`/${article.slug}/`}>{article.data.title}</a>
            <br/><small>{article.data.description}</small>
          </li>
        ))}
      </ul>
    </div>
  </article>
</BaseLayout>
