---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).filter(e => !e.data.hideFromHome && !e.data.draft);
articles.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const featured = articles.slice(0, 6);

const DEFAULT_OG = '/og-image.jpg';

const homeSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ANU Wiki',
  url: 'https://anu.wiki',
  description: 'The independent knowledge base for the Australian National University — admissions, academics, campus life, and student services.',
  inLanguage: 'en',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://anu.wiki/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
});
---

<BaseLayout
  title="ANU Wiki — Your Independent Guide to the Australian National University"
  description="Comprehensive guide to the Australian National University: admissions, academics, campus life, student services, and everything you need to know about studying at ANU."
  schema={homeSchema}
>
  <!-- Hero -->
  <header class="ehero">
    <div class="ehero-inner">
      <div class="eeyebrow">ANU Wiki · Independent Knowledge Base</div>
      <h1>Everything About the Australian National University</h1>
      <p class="elead">Admissions, academics, campus life, and student services — your complete guide to ANU</p>
      <div class="ehero-actions">
        <a href="/#articles">Browse Articles</a>
        <a href="/about/">About</a>
      </div>
    </div>
    <div class="escroll-cue">SCROLL ↓</div>
  </header>

  <!-- Featured Articles -->
  <section class="earticles" id="articles">
    <div class="ewrap">
      <div class="esec-head">
        <div class="ekicker">Latest Articles</div>
        <h2>Recent ANU Guides</h2>
      </div>
      <div class="egrid">
        {featured.map((article) => (
          <a href={`/${article.slug}/`} class="epost">
            <div class="ethumb">
              <img src={article.data.ogImage || DEFAULT_OG} alt={article.data.title} loading="lazy" />
              <span class="ecat">{article.data.category}</span>
            </div>
            <div class="ebody">
              <h3>{article.data.title}</h3>
              <p>{article.data.description || ''}</p>
              <div class="emeta">
                <time>{article.data.publishDate}</time>
                {article.data.readingTime && (<><span class="edot"></span><span>{article.data.readingTime} min</span></>)}
              </div>
            </div>
          </a>
        ))}
      </div>
      <a href="/#articles" class="emore-link">View All Articles →</a>
    </div>
  </section>

  <!-- CTA Band -->
  <section>
    <div class="ewrap">
      <div class="ecta-band" id="cta">
        <h2>Can't find what you're looking for?</h2>
        <p>Our team is continuously expanding the ANU Wiki. Let us know what topics you'd like to see.</p>
        <a href="/#articles" class="ebtn ebtn-primary">Browse All Articles</a>
      </div>
    </div>
  </section>
</BaseLayout>
