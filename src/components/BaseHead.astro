---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  schema?: string;
}

const {
  title,
  description,
  ogImage = '/og-image.jpg',
  canonicalURL,
  schema,
} = Astro.props;

const SITE_NAME = 'ANU Wiki';
const BASE_URL = 'https://anu.wiki';
const resolvedCanonical = canonicalURL || new URL(Astro.url.pathname, BASE_URL).toString();

// Ensure og:image is always an absolute URL
const resolvedOgImage = ogImage && (ogImage.startsWith('http') ? ogImage : BASE_URL + (ogImage.startsWith('/') ? '' : '/') + ogImage);
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{(title.includes(SITE_NAME) || title === SITE_NAME) ? title : title + " — " + SITE_NAME}</title>
<meta name="description" content={description} />
<link rel="canonical" href={resolvedCanonical} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:type" content="article" />
<meta property="og:site_name" content={SITE_NAME} />

<meta name="twitter:card" content="summary_large_image" />

<!-- robots: allow all crawlers including AI -->
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
<meta name="ai" content="allow" />

{schema && <script type="application/ld+json" set:html={schema} />}
